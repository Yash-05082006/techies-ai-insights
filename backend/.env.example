# PostgreSQL (Neon) — app converts postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Comma-separated frontend origins
CORS_ORIGINS=http://localhost:8080

# Optional — used by optimization agent in a later phase
OPENAI_API_KEY=

# Google Gemini — used by proxy when application.provider=google
GEMINI_API_KEY=

LOG_LEVEL=INFO
