# PostgreSQL (Neon) — app converts postgresql:// to postgresql+asyncpg://
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Comma-separated frontend origins (localhost + 127.0.0.1 for Vite/TanStack dev servers)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://localhost:8081,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8080,http://127.0.0.1:8081

# Optional — used by optimization agent in a later phase
OPENAI_API_KEY=

# Google Gemini — used by proxy when application.provider=google
GEMINI_API_KEY=

LOG_LEVEL=INFO
