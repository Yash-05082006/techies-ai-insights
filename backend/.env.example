# PostgreSQL connection (Neon or local).
# The app converts postgresql:// to postgresql+asyncpg:// automatically.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT settings (used in Phase 2 — auth)
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:8080

# Optional — used by the optimization agent in a later phase
OPENAI_API_KEY=

LOG_LEVEL=INFO
